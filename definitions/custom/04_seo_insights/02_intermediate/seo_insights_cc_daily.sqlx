config {
  type: "incremental",
  schema: dataform.projectConfig.vars.OUTPUTS_DATASET,
  tags: [dataform.projectConfig.vars.LABEL_EXECUTION_OPERATION, "seo_insights", "cc", "daily"],
  description: "Daily qualified leads for SEO Insights from cc_gold (cc_leads_master for cash, cc_leads_security for security).",
  bigquery: {
    partitionBy: "activity_date",
    clusterBy: ["market", "kpi"]
  }
}

js {
  const seoInsights = require("includes/custom/seo_insights_config");
}

pre_operations {
  declare date_checkpoint DATE;
  set date_checkpoint = (
    ${when(incremental(),
      `SELECT COALESCE(DATE_SUB(MAX(activity_date), INTERVAL 7 DAY), DATE('${seoInsights.SOURCE_START_DATE}')) FROM ${self()}`,
      `SELECT DATE('${seoInsights.SOURCE_START_DATE}')`
    )}
  );
  ${when(incremental(),
    `DELETE FROM ${self()} WHERE activity_date >= date_checkpoint`
  )}
}

${seoInsights.buildCcDailySql({ dateLowerBoundExpression: "date_checkpoint" })}
